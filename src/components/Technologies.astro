---
// Technologies.astro
import fs from 'node:fs';
import path from 'node:path';

// Directorio donde residen los logotipos descargados
const techDir = path.join(process.cwd(), 'public', 'images', 'tech');

const rawTechnologies = [
  { name: 'HTML5', icon: 'html5', color: '#e34f26' },
  { name: 'CSS3', icon: 'css3', color: '#1572b6' },
  { name: 'JavaScript', icon: 'javascript', color: '#f7df1e' },
  { name: 'TypeScript', icon: 'typescript', color: '#3178c6' },
  { name: 'Astro', icon: 'astro', color: '#bc52ee' },
  { name: 'Tailwind CSS', icon: 'tailwindcss', color: '#38bdf8' },
  { name: 'Node.js', icon: 'nodedotjs', color: '#339933' },
  { name: 'Python', icon: 'python', color: '#3776ab' },
  { name: 'SQL', icon: 'mysql', color: '#00758f' },
  { name: 'Git', icon: 'git', color: '#f05032' },
  { name: 'GitHub', icon: 'github', color: '#e2e8f0' },
  { name: 'Docker', icon: 'docker', color: '#2496ed' },
  { name: 'Linux', icon: 'linux', color: '#fcc624' },
  { name: 'Figma', icon: 'figma', color: '#f24e1e' },
  { name: 'VS Code', icon: 'visualstudiocode', color: '#007acc' },
  { name: 'Vercel', icon: 'vercel', color: '#ffffff' },
  { name: 'Cloudflare', icon: 'cloudflare', color: '#f38020' },
  { name: 'WordPress', icon: 'wordpress', color: '#21759b' },
  { name: 'Shopify', icon: 'shopify', color: '#7ab55c' },
  { name: 'Jira', icon: 'jirasoftware', color: '#0052cc' }
];

const technologies = rawTechnologies.map(tech => {
  let svgContent = '';
  try {
    const filePath = path.join(techDir, `${tech.icon}.svg`);
    let rawSvg = fs.readFileSync(filePath, 'utf-8');
    
    // Inyectamos las clases necesarias y el fill="currentColor" para mantener la interactividad CSS actual.
    // Además, eliminamos posibles atributos fijos de width/height para que se controle por CSS del componente.
    svgContent = rawSvg
      .replace(/<svg\s/, '<svg class="svg-icon" fill="currentColor" aria-hidden="true" ')
      .replace(/\s(width|height)="[^"]*"/g, '');
  } catch (e) {
    console.error(`Error al leer el logo para ${tech.name}:`, e);
  }
  return { ...tech, svgContent };
});
---

<section id="tecnologias" class="tech-section">
  <div class="section-header">
    <h2 class="section-title">Tecnologías</h2>
    <div class="accent-line"></div>
  </div>

  <div class="grid-container">
    <div class="tech-grid-apple">
      {technologies.map((tech, idx) => (
        <div class="chip-wrapper" style={`--delay: ${idx * 0.12}s;`}>
          <div 
            class="tech-chip" 
            style={`--brand-color: ${tech.color}`}
            aria-label={`Tecnología: ${tech.name}`}
            tabindex="0"
          >
            <div class="tech-icon-container">
              <Fragment set:html={tech.svgContent} />
            </div>
            <span class="tech-name">{tech.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  .tech-section {
    padding: 120px 40px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 10;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .tech-section {
      padding: 80px 20px;
    }
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 50px;
    text-align: center;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    transition: color 0.4s ease;
  }

  .accent-line {
    width: 40px;
    height: 4px;
    background: var(--text-primary);
    border-radius: 2px;
    opacity: 0.9;
    transition: background-color 0.4s ease;
  }

  /* Grid Container */
  .grid-container {
    width: 100%;
    max-width: 960px;
    display: flex;
    justify-content: center;
    padding: 20px 0;
  }

  /* Cuadrícula Apple de 5 columnas en desktop */
  .tech-grid-apple {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    width: 100%;
  }

  @media (max-width: 900px) {
    .tech-grid-apple {
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
  }

  @media (max-width: 640px) {
    .tech-grid-apple {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  /* Wrapper para aislar la animación flotante del hover */
  .chip-wrapper {
    animation: float-gentle 5s ease-in-out infinite;
    animation-delay: var(--delay);
    display: flex;
    justify-content: center;
    width: 100%;
    will-change: transform;
  }

  .chip-wrapper:hover {
    animation-play-state: paused;
  }

  @keyframes float-gentle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* Chip estilo cristal Apple */
  .tech-chip {
    width: 100%;
    background: var(--navbar-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--navbar-border);
    border-radius: 20px;
    height: 52px;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    cursor: default;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                background-color 0.3s ease,
                border-color 0.3s ease,
                box-shadow 0.3s ease,
                color 0.3s ease;
    outline: none;
  }

  @media (max-width: 640px) {
    .tech-chip {
      height: 46px;
      padding: 0 14px;
      gap: 8px;
      border-radius: 16px;
    }
  }

  /* Focus visible para accesibilidad por teclado */
  .tech-chip:focus-visible {
    border-color: var(--brand-color);
    box-shadow: 0 0 0 2px var(--brand-color);
  }

  /* Hover Apple Premium */
  .tech-chip:hover, .tech-chip:focus-visible {
    transform: translateY(-4px) scale(1.03);
    background-color: color-mix(in srgb, var(--brand-color) 6%, var(--navbar-bg));
    border-color: var(--brand-color);
    box-shadow: 0 12px 24px -10px color-mix(in srgb, var(--brand-color) 30%, transparent),
                0 0 15px -4px color-mix(in srgb, var(--brand-color) 12%, transparent);
    color: var(--text-primary);
  }

  /* Icono por defecto neutro elegante estilo Apple */
  .tech-icon-container {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--social-link-color);
    opacity: 0.85;
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease, opacity 0.3s ease;
  }

  .tech-chip:hover .tech-icon-container, .tech-chip:focus-visible .tech-icon-container {
    color: var(--brand-color);
    opacity: 1;
    transform: scale(1.1) rotate(2deg);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--brand-color) 50%, transparent));
  }

  .svg-icon {
    width: 100%;
    height: 100%;
    max-width: 20px;
    max-height: 20px;
  }

  @media (max-width: 640px) {
    .svg-icon {
      max-width: 17px;
      max-height: 17px;
    }
  }

  /* Nombre de tecnología por defecto */
  .tech-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--social-link-color);
    transition: color 0.3s ease;
    white-space: nowrap;
    letter-spacing: 0.2px;
  }

  @media (max-width: 640px) {
    .tech-name {
      font-size: 0.8rem;
    }
  }

  .tech-chip:hover .tech-name, .tech-chip:focus-visible .tech-name {
    color: var(--text-primary);
  }

  /* Tema claro */
  :global(.light-theme) .tech-chip:hover,
  :global(.light-theme) .tech-chip:focus-visible {
    background-color: color-mix(in srgb, var(--brand-color) 8%, rgba(255, 255, 255, 0.95));
    border-color: color-mix(in srgb, var(--brand-color) 85%, #78716c);
    box-shadow: 0 10px 20px -8px color-mix(in srgb, var(--brand-color) 25%, transparent),
                0 0 10px -3px color-mix(in srgb, var(--brand-color) 12%, transparent);
  }
</style>
