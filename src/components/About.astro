---
// About.astro
const skills = [
  { category: 'Frontend', items: ['Astro', 'React', 'Next.js', 'TypeScript', 'Tailwind CSS'] },
  { category: 'Backend', items: ['Node.js', 'Express', 'Python', 'FastAPI', 'WebSockets'] },
  { category: 'Herramientas', items: ['Git', 'Docker', 'Vite', 'Figma', 'Linux'] }
];

const coreValues = [
  {
    title: 'Diseño Inmersivo',
    description: 'Interfaces interactivas donde la estética y la usabilidad se unen para contar historias digitales.',
    icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5'
  },
  {
    title: 'Arquitectura Limpia',
    description: 'Código modular, escalable y optimizado para lograr tiempos de carga imperceptibles y mantenibilidad.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'
  }
];
---

<section id="sobre-mi" class="about-section">
  <div class="section-header">
    <h2 class="section-title">Sobre Mí</h2>
    <div class="accent-line"></div>
  </div>

  <div class="about-content">
    <div class="about-visual">
      <div class="image-frame-glow"></div>
      <div class="image-frame">
        <img src="/images/profile-avatar.png" alt="Avatar Alejandro Laglera" class="profile-image" loading="lazy" />
        <div class="image-overlay"></div>
      </div>
    </div>

    <div class="about-text-container">
      <div class="bio-intro">
        <h3>Creador de experiencias digitales minimalistas y de alto rendimiento.</h3>
        <p class="bio-paragraph">
          Soy <strong>Alejandro Laglera</strong>. Mi enfoque se centra en fusionar la estética visual del diseño moderno con la robustez y optimización de la ingeniería de software. Me especializo en el ecosistema JavaScript/TypeScript, construyendo soluciones de extremo a extremo que no solo funcionan a la perfección, sino que deleitan al usuario a primera vista.
        </p>
        <p class="bio-paragraph">
          Creo firmemente en la atención al detalle, el rendimiento web sobresaliente y la creación de interfaces vivas que reaccionan a la interacción con micro-animaciones fluidas.
        </p>
      </div>

      <div class="values-grid">
        {coreValues.map(value => (
          <div class="value-card">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={value.icon} />
              </svg>
            </div>
            <div class="value-info">
              <h4>{value.title}</h4>
              <p>{value.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="skills-wrapper">
        <h4 class="skills-title">Tecnologías & Herramientas</h4>
        <div class="skills-categories">
          {skills.map(skillGroup => (
            <div class="skills-group">
              <h5>{skillGroup.category}</h5>
              <div class="skills-tags">
                {skillGroup.items.map(skill => (
                  <span class="skill-tag">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 100px 40px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 10;
  }

  @media (max-width: 768px) {
    .about-section {
      padding: 80px 20px;
    }
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 64px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .section-header {
      margin-bottom: 40px;
    }
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    transition: color 0.4s ease;
  }

  .accent-line {
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, #1e40af, #3b82f6);
    border-radius: 2px;
  }

  /* Grid Layout */
  .about-content {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 64px;
    width: 100%;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .about-content {
      gap: 40px;
    }
  }

  @media (max-width: 860px) {
    .about-content {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  /* Left Column: Visual avatar */
  .about-visual {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1;
    margin: 0 auto;
  }

  .image-frame-glow {
    position: absolute;
    inset: -4px;
    border-radius: 24px;
    background: linear-gradient(135deg, #1d4edf, #3b82f6, #60a5fa);
    filter: blur(12px);
    opacity: 0.35;
    z-index: 1;
    transition: opacity 0.4s ease, filter 0.4s ease;
  }

  .about-visual:hover .image-frame-glow {
    opacity: 0.6;
    filter: blur(16px);
  }

  .image-frame {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    z-index: 2;
    transition: border-color 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-visual:hover .image-frame {
    border-color: var(--card-hover-border);
    transform: scale(1.02) translateY(-4px);
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-visual:hover .profile-image {
    transform: scale(1.04);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(2, 6, 23, 0.35) 100%);
    pointer-events: none;
  }

  /* Right Column: Text & Skills */
  .about-text-container {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .bio-intro h3 {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    line-height: 1.4;
    color: var(--text-primary);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .bio-paragraph {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 16px;
    text-align: justify;
  }

  .bio-paragraph strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Values Cards */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 8px;
  }

  @media (max-width: 580px) {
    .values-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .value-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    gap: 16px;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.4s ease;
  }

  .value-card:hover {
    transform: translateY(-2px);
    border-color: var(--card-hover-border);
  }

  .value-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .value-info h4 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .value-info p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Skills tags */
  .skills-wrapper {
    margin-top: 12px;
    border-top: 1px solid var(--card-border);
    padding-top: 28px;
  }

  .skills-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
  }

  .skills-categories {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .skills-group h5 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-tag {
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    border-radius: 8px;
    color: var(--tag-text);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 6px 14px;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .skill-tag:hover {
    background: var(--tag-hover-bg);
    border-color: var(--tag-hover-border);
    color: var(--text-primary);
    transform: translateY(-1px);
  }
</style>
