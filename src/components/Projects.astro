---
// Projects.astro
import { projects } from '../data/projects';
---

<section id="proyectos" class="projects-section">
  <div class="section-header">
    <h2 class="section-title">Mis Proyectos</h2>
    <div class="accent-line"></div>
  </div>

  <div class="projects-grid">
    {projects.map((project) => (
      <article class="project-card">
        <a href={`/proyectos/${project.slug}`} class="project-link-wrapper" aria-label={`Detalles del proyecto ${project.title}`}>
          <div class="project-image-wrapper">
            <img src={project.image} alt={project.title} loading="lazy" class="project-image" />
            <div class="image-overlay"></div>
          </div>
        </a>
        <div class="project-info">
          <h3 class="project-title">
            <a href={`/proyectos/${project.slug}`} class="project-title-link">{project.title}</a>
          </h3>
          <p class="project-description">{project.description}</p>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag-badge">{tag}</span>
            ))}
          </div>
          <div class="project-links">
            <a href={`/proyectos/${project.slug}`} class="link-btn primary" aria-label={`Ver detalles de ${project.title}`}>
              <span>Ver detalles</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="link-btn secondary" aria-label={`Ver repositorio de ${project.title}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              <span>Código</span>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .projects-section {
    padding: 100px 40px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 10;
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 80px 20px;
    }
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 64px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .section-header {
      margin-bottom: 40px;
    }
  }

  .subtitle-badge {
    display: inline-block;
    padding: 6px 16px;
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    border-radius: 100px;
    color: var(--tag-text);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
    transition: background 0.4s ease, border-color 0.4s ease, color 0.4s ease;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    transition: color 0.4s ease;
  }

  .accent-line {
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, #1e40af, #3b82f6);
    border-radius: 2px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 680px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  /* Card Styles */
  .project-card {
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                background 0.4s ease;
    box-shadow: var(--card-shadow);
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--card-hover-border);
    box-shadow: var(--card-hover-shadow);
  }

  /* Image container */
  .project-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/8;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 40%, rgba(0, 0, 0, 0) 100%);
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 40%, rgba(0, 0, 0, 0) 100%);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .project-image {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(2, 6, 23, 0.4) 100%);
    pointer-events: none;
  }

  .project-link-wrapper {
    display: block;
    width: 100%;
    text-decoration: none;
    overflow: hidden;
  }

  .project-title-link {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .project-card:hover .project-title-link {
    color: #3b82f6;
  }

  :global(.light-theme) .project-card:hover .project-title-link {
    color: #1e40af;
  }

  /* Info container */
  .project-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
    transition: color 0.4s ease;
  }

  .project-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.4s ease;
  }

  /* Tags */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
    margin-top: auto; /* Push tags and links to bottom */
  }

  .tag-badge {
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    border-radius: 6px;
    color: var(--tag-text);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 10px;
    letter-spacing: 0.2px;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
  }

  .project-card:hover .tag-badge {
    background: var(--tag-hover-bg);
    border-color: var(--tag-hover-border);
    color: var(--text-primary);
  }

  /* Links container */
  .project-links {
    display: flex;
    gap: 12px;
  }

  .link-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .link-btn.primary {
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
  }

  .link-btn.primary:hover {
    background: var(--btn-primary-hover-bg);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.15);
  }

  .link-btn.secondary {
    background: var(--btn-secondary-bg);
    border: 1px solid var(--btn-secondary-border);
    color: var(--btn-secondary-text);
  }

  .link-btn.secondary:hover {
    background: var(--btn-secondary-hover-bg);
    border-color: var(--btn-secondary-hover-border);
    transform: translateY(-2px);
  }
</style>
