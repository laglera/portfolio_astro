---
// Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-divider"></div>
    <div class="footer-content">
      <div class="footer-left">
        <p class="copyright">
          &copy; {currentYear} Alejandro Laglera. Todos los derechos reservados.
        </p>
      </div>
      
      <div class="footer-right">
        <div class="footer-links">
          <a href="#proyectos" class="footer-link">Proyectos</a>
          <a href="#formacion" class="footer-link">Formación</a>
          <a href="#tecnologias" class="footer-link">Tecnologías</a>
          <a href="#contacto" class="footer-link">Contacto</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    padding: 40px 0 60px 0;
    position: relative;
    z-index: 10;
  }

  .footer-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 600px) {
    .footer-container {
      padding: 0 20px;
    }
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    background: var(--navbar-border);
    opacity: 0.6;
    margin-bottom: 30px;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column-reverse;
      text-align: center;
      gap: 16px;
    }
  }

  .copyright {
    font-size: 0.8rem;
    color: var(--social-link-color);
    opacity: 0.8;
    letter-spacing: -0.01em;
    font-weight: 400;
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  @media (max-width: 768px) {
    .footer-links {
      gap: 18px;
      justify-content: center;
      flex-wrap: wrap;
    }
  }

  .footer-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--social-link-color);
    text-decoration: none;
    transition: color 0.3s ease;
    letter-spacing: 0.1px;
  }

  .footer-link:hover {
    color: var(--social-link-hover);
  }
</style>
